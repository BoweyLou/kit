{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-codereview/review-map.schema.json",
  "title": "Agent Review Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_map",
    "source_inputs",
    "scope_summary",
    "change_clusters",
    "inspection_plan",
    "risk_hotspots",
    "reviewer_routing",
    "recommended_sequence",
    "validation_evidence",
    "omissions_uncertainty",
    "follow_up_task_packet_candidates",
    "disposition"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "review_map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repo",
        "created_at",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "description": "Local timestamp or date-time for the map artifact."
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "ready-for-review",
            "blocked",
            "superseded"
          ]
        },
        "owner": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_range",
        "changed_files",
        "context_packet",
        "context_bundle",
        "task_packet",
        "receipts",
        "manual_inspection_notes"
      ],
      "properties": {
        "diff_range": {
          "type": "string",
          "minLength": 1
        },
        "changed_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path_note"
          }
        },
        "context_packet": {
          "$ref": "#/$defs/artifact_reference"
        },
        "context_bundle": {
          "$ref": "#/$defs/artifact_reference"
        },
        "task_packet": {
          "$ref": "#/$defs/artifact_reference"
        },
        "receipts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "manual_inspection_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scope_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_objective",
        "change_summary",
        "out_of_scope",
        "assumptions"
      ],
      "properties": {
        "review_objective": {
          "type": "string",
          "minLength": 1
        },
        "change_summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "change_clusters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/change_cluster"
      }
    },
    "inspection_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entrypoints",
        "public_contracts",
        "data_schema_boundaries",
        "operational_surfaces",
        "docs_and_adrs",
        "scripts",
        "tests"
      ],
      "properties": {
        "entrypoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inspection_target"
          }
        },
        "public_contracts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inspection_target"
          }
        },
        "data_schema_boundaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inspection_target"
          }
        },
        "operational_surfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inspection_target"
          }
        },
        "docs_and_adrs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inspection_target"
          }
        },
        "scripts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inspection_target"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inspection_target"
          }
        }
      }
    },
    "risk_hotspots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk_hotspot"
      }
    },
    "reviewer_routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_personas",
        "specialist_personas",
        "skipped_personas"
      ],
      "properties": {
        "default_personas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/persona_route"
          }
        },
        "specialist_personas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/persona_route"
          }
        },
        "skipped_personas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/persona_skip"
          }
        }
      }
    },
    "recommended_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/review_step"
      }
    },
    "validation_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands",
        "receipts_to_capture",
        "docs_and_adr_checks",
        "runtime_or_config_checks",
        "evidence_gaps"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validation_item"
          }
        },
        "receipts_to_capture": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "docs_and_adr_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validation_item"
          }
        },
        "runtime_or_config_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validation_item"
          }
        },
        "evidence_gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/omission"
          }
        }
      }
    },
    "omissions_uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skipped_files",
        "unclassified_paths",
        "missing_context_data",
        "ambiguous_ownership",
        "validation_gaps",
        "other_unknowns"
      ],
      "properties": {
        "skipped_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/omission"
          }
        },
        "unclassified_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/omission"
          }
        },
        "missing_context_data": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/omission"
          }
        },
        "ambiguous_ownership": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/omission"
          }
        },
        "validation_gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/omission"
          }
        },
        "other_unknowns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/omission"
          }
        }
      }
    },
    "follow_up_task_packet_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/follow_up_candidate"
      }
    },
    "disposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "map_status",
        "handoff_notes"
      ],
      "properties": {
        "map_status": {
          "type": "string",
          "enum": [
            "draft",
            "ready-for-review",
            "blocked",
            "superseded"
          ]
        },
        "handoff_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reference"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "available",
            "missing",
            "stale",
            "blocked",
            "ambiguous",
            "not-applicable"
          ]
        },
        "reference": {
          "type": [
            "string",
            "null"
          ],
          "description": "Repo-relative path, local command, run id, receipt id, or null when unavailable."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "path_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "note"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      }
    },
    "change_cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "rationale",
        "owner_or_area",
        "changed_files",
        "supporting_context",
        "uncertainty"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "owner_or_area": {
          "type": "string",
          "minLength": 1
        },
        "changed_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/path_note"
          }
        },
        "supporting_context": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_reference"
          }
        },
        "uncertainty": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "inspection_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "reason",
        "status"
      ],
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "inspect",
            "inspected",
            "skipped",
            "blocked",
            "not-applicable"
          ]
        },
        "source": {
          "type": "string"
        }
      }
    },
    "risk_hotspot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "priority",
        "paths",
        "reason",
        "personas",
        "evidence_needed"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "personas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_needed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "persona_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persona",
        "scope"
      ],
      "properties": {
        "persona": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "persona_skip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persona_or_area",
        "reason",
        "residual_risk"
      ],
      "properties": {
        "persona_or_area": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "residual_risk": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "objective",
        "inspect",
        "exit_criteria"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "inspect": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exit_criteria": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "expected_result",
        "status"
      ],
      "properties": {
        "item": {
          "type": "string",
          "minLength": 1
        },
        "expected_result": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "required",
            "optional",
            "passed",
            "failed",
            "skipped",
            "blocked",
            "not-applicable"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "omission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "reason",
        "residual_risk"
      ],
      "properties": {
        "item": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "residual_risk": {
          "type": "string",
          "minLength": 1
        },
        "next_source_to_inspect": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "follow_up_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "rationale",
        "likely_scope",
        "priority",
        "trigger"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "likely_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3",
            "unknown"
          ]
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
